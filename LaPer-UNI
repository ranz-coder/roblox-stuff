flyDownBtn.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then isHoldingDown = false end end)

UserInputService.JumpRequest:Connect(function()
	if infJumpEnabled then
		pcall(function()
			local char = localPlayer.Character
			local hum = char and char:FindFirstChild("Humanoid")
			if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
		end)
	end
end)

localPlayer.CharacterAdded:Connect(function(char)
	task.wait(0.5)
	if flySettings.Enabled then flySettings.Enabled = false flyControlFrame.Visible = false end
end)

RunService.Heartbeat:Connect(function(deltaTime)
	pcall(function()
		local char = localPlayer.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		local hum = char and char:FindFirstChild("Humanoid")
		
		if hrp and hum then
			if speedSettings.Enabled and speedSettings.TargetSpeed > 16 and not flySettings.Enabled then
				if hum.MoveDirection.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (hum.MoveDirection * ((speedSettings.TargetSpeed - 16) * deltaTime)) end
			else
				if hum.WalkSpeed ~= 16 and not speedSettings.Enabled and not flySettings.Enabled then hum.WalkSpeed = 16 end
			end

			if jumpSettings.Enabled then
				hum.UseJumpPower = true
				if hum.JumpPower ~= jumpSettings.TargetPower then hum.JumpPower = jumpSettings.TargetPower end
			end

			if wallhopEnabled then
				if hum.FloorMaterial == Enum.Material.Air and hum.MoveDirection.Magnitude > 0 then
					local origin = hrp.Position
					local direction = hum.MoveDirection * 2
					local rayParams = RaycastParams.new()
					rayParams.FilterPlayers = {char}
					rayParams.FilterType = Enum.RaycastFilterType.Exclude
					if workspace:Raycast(origin, direction, rayParams) then
						hrp.Velocity = Vector3.new(hrp.Velocity.X, jumpSettings.TargetPower > 50 and jumpSettings.TargetPower or 50, hrp.Velocity.Z)
					end
				end
			end

			if flySettings.Enabled then
				if hrp.Anchored ~= true then hrp.Anchored = true end
				local camCF = workspace.CurrentCamera.CoordinateFrame
				local moveDir = hum.MoveDirection
				local calcCF = hrp.CFrame
				
				if moveDir.Magnitude > 0 then
					local dirVec = (camCF.LookVector * (moveDir.Z * -1) + camCF.RightVector * moveDir.X).Unit
					calcCF = calcCF + (dirVec * (flySettings.Speed * 15 * deltaTime))
				end
				
				if isHoldingUp then calcCF = calcCF + Vector3.new(0, flySettings.Speed * 15 * deltaTime, 0)
				elseif isHoldingDown then calcCF = calcCF + Vector3.new(0, -(flySettings.Speed * 15 * deltaTime), 0) end
				
				hrp.CFrame = calcCF
			else
				if hrp.Anchored == true then hrp.Anchored = false end
			end
		end
	end)
end)

