	statusLabel.Font = Enum.Font.GothamBlack
	statusLabel.TextSize = 11
	statusLabel.Parent = rowFrame

	local state = false
	switchTrack.Activated:Connect(function()
		state = not state
		if inputField then
			local num = tonumber(inputField.Text)
			if num then onInputCallback(num) end
		end
		if state then
			switchBall.Position = UDim2.new(1, -21, 0.5, -9)
