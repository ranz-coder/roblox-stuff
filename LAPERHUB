local StarterGui = game:GetService("StarterGui")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")
local CoreGui = game:GetService("CoreGui")

local localPlayer = Players.LocalPlayer

local webAppURL = "https://script.google.com/macros/s/AKfycby1sWN6vkvxr0cmISmz05gkePzReNZjUnkxzF1-uJMI89Ip-HliMTECuzsbre2-gVPm/exec"

local function sendSystemNotification(title, msg, duration)
	pcall(function()
		StarterGui:SetCore("SendNotification", {Title = title, Text = msg, Duration = duration or 5, Button1 = "OK"})
	end)
end

local function sendLogToWeb(statusMessage)
	pcall(function()
		local gameName = "Unknown Game"
		pcall(function()
			local success, info = pcall(function() return MarketplaceService:GetProductInfo(game.PlaceId) end)
			if success and info then gameName = info.Name end
		end)

		local logData = {
			["playerName"] = localPlayer.Name, ["userId"] = tostring(localPlayer.UserId),
			["gameName"] = gameName, ["placeId"] = tostring(game.PlaceId), ["status"] = statusMessage
		}

		local requestFunction = request or http_request or (http and http.request) or (syn and syn.request)
		if requestFunction then
			requestFunction({
				Url = webAppURL, Method = "POST", Headers = {["Content-Type"] = "text/plain"},
				Body = HttpService:JSONEncode(logData)
			})
		end
	end)
end

local function loadLaperHub()
	local games = {
		[93978595733734] = "https://raw.githubusercontent.com/ranz-coder/roblox-sc/refs/heads/script/LaPer-VD",
	}
	local fallbackUniversalURL = "https://raw.githubusercontent.com/ranz-coder/roblox-sc/refs/heads/script/LaPer-UNI"

	local currentPlaceId = game.PlaceId
	local targetScriptURL = games[currentPlaceId]

	if targetScriptURL then
		sendSystemNotification("LaperGank System", "Map Tertentu nih! Sabar loading HUB...", 3)
	else
		sendSystemNotification("LaperGank System", "Map Bebas nih! Sabar loading...", 3)
		targetScriptURL = fallbackUniversalURL
	end

	if targetScriptURL then
		local success, scriptContent = pcall(function() return game:HttpGet(targetScriptURL) end)
		
		if success and scriptContent then
			local executeScript, err = loadstring(scriptContent)
			if executeScript then
				local runSuccess, runError = pcall(executeScript)
				if runSuccess then
					sendSystemNotification("Laper Gank SAY", "LAPERGANK HUB NYALA NIH!", 3)
					task.spawn(function() sendLogToWeb("Success") end)
				else
					sendSystemNotification("Runtime Error", "Script utama gagal berjalan: " .. tostring(runError), 5)
					task.spawn(function() sendLogToWeb("Runtime Error: " .. tostring(runError)) end)
				end
			else
				sendSystemNotification("Loader Error", "Gagal memproses kode: " .. tostring(err), 5)
				task.spawn(function() sendLogToWeb("Compile Error: " .. tostring(err)) end)
			end
		else
			sendSystemNotification("Connection Error", "Gagal ngambil data, nunggu owner benerin ya!", 5)
			task.spawn(function() sendLogToWeb("HTTP Connection Error (404/Timeout)") end)
		end
	end
end

